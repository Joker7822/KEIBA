function get_race_result_horse_laptime(_id, _show_id, _credit=0)
{
var _data = {};
_data.input    = 'UTF-8';
_data.output   = 'jsonp';
_data.id  = _id;
_data.credit = _credit;
$.ajax( { type     : 'GET',
url      : 'https://db.netkeiba.com/race/ajax_race_result_horse_laptime.html',
data     : _data,
dataType : _data.output,
success  : function( elm ){
$('#'+_show_id).after(elm);
},
complete : function (){}
});
}
</script>
