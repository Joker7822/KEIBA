<script>
function get_race_note_form(_id, _show_id, _all_horse=0, _self_url='')
{
var _data = {};
_data.input    = 'UTF-8';
_data.output   = 'jsonp';
_data.id  = _id;
_data.all_horse = _all_horse;
_data.rtn_url = _self_url;
$.ajax( { type     : 'GET',
url      : 'https://db.netkeiba.com/race/ajax_race_note_form.html',
data     : _data,
dataType : _data.output,
success  : function( elm ){
$('#'+_show_id).after(elm);
},
complete : function (){}
});
}
</script>
<script type="text/javascript">
$(function () {
get_race_note_form('202209060703', 'Race_Note_Form', 1, 'https%3A%2F%2Fdb.netkeiba.com%2F%2Frace%2F202209060703');
});
</script>

