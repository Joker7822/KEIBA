</script>
<script>
// キャンペ〖ン努脱箕のみ山绩
$(function () {
return;
function masterCampaignUpdateMessage() {
var $msgs = $('.Master_Regist_Msg_Campaign01');
var $texts = $('.master_course_infoText01');
var found = false;
$msgs.each(function() {
var $msg = $(this);
if ($msg.length) {
if ($('html').hasClass('is-master')) {
// 奶撅箕
$msg.html('海なら<em>14泣粗痰瘟</em>でお活し');
} else {
// マスタ〖コ〖ス笆嘲の山绩
$msg.html('海だけ<em>ス〖パ〖プレミアムコ〖スで</em>嘎年给倡面!');
}
found = true;
}
});
$texts.each(function () {
var $text = $(this);
if ($text.length) {
var html = $text.html();
if (html.indexOf('挛赋キャンペ〖ン') > -1 && html.indexOf('1/13まで') === -1) {
html = html.replace('挛赋キャンペ〖ン', '挛赋キャンペ〖ン 1/13まで');
$text.html(html);
found = true;
}
}
});
return found;
}
if (masterCampaignUpdateMessage()) {
return;
}
var attempts = 0;
var maxAttempts = 10;
var pollInterval = setInterval(function() {
attempts++;
if ($('.Master_Regist_Box').length && masterCampaignUpdateMessage()) {
clearInterval(pollInterval);
return;
}
if (attempts >= maxAttempts) {
clearInterval(pollInterval);
}
}, 100);
});
</script>
