<script>
// ¥­¥م¥َ¥ع،¼¥َإ¬حر»‏¤خ¤كة½¼¨
$(function () {
return;
function masterCampaignUpdateMessage() {
var $msgs = $('.Master_Regist_Msg_Campaign01');
var $texts = $('.master_course_infoText01');
var found = false;
$msgs.each(function() {
var $msg = $(this);
if ($msg.length) {
if ($('html').hasClass('is-master')) {
// ؤج¾ï»‏
$msg.html('؛£¤ت¤é<em>14ئü´ضجµخء</em>¤ا¤ھ»î¤·');
} else {
// ¥ق¥¹¥؟،¼¥³،¼¥¹°ت³°¤خة½¼¨
$msg.html('؛£¤ہ¤±<em>¥¹،¼¥ر،¼¥×¥ى¥ك¥¢¥à¥³،¼¥¹¤ا</em>¸آؤê¸ّ³«أو!');
}
found = true;
}
});
$texts.each(function () {
var $text = $(this);
if ($text.length) {
var html = $text.html();
if (html.indexOf('آخ¸³¥­¥م¥َ¥ع،¼¥َ') > -1 && html.indexOf('1/13¤ق¤ا') === -1) {
html = html.replace('آخ¸³¥­¥م¥َ¥ع،¼¥َ', 'آخ¸³¥­¥م¥َ¥ع،¼¥َ 1/13¤ق¤ا');
$text.html(html);
found = true;
}
}
});
return found;
}
if (masterCampaignUpdateMessage()) {
return;
}
var attempts = 0;
var maxAttempts = 10;
var pollInterval = setInterval(function() {
attempts++;
if ($('.Master_Regist_Box').length && masterCampaignUpdateMessage()) {
clearInterval(pollInterval);
return;
}
if (attempts >= maxAttempts) {
clearInterval(pollInterval);
}
}, 100);
});
</script>
