<script>
// Ѕ­ЅуЅѓЅкЁМЅѓХЌЭбЛўЄЮЄпЩНМЈ
$(function () {
return;
function masterCampaignUpdateMessage() {
var $msgs = $('.Master_Regist_Msg_Campaign01');
var $texts = $('.master_course_infoText01');
var found = false;
$msgs.each(function() {
var $msg = $(this);
if ($msg.length) {
if ($('html').hasClass('is-master')) {
// ФЬОяЛў
$msg.html('КЃЄЪЄщ<em>14ЦќДжЬЕЮС</em>ЄЧЄЊЛюЄЗ');
} else {
// ЅоЅЙЅПЁМЅГЁМЅЙАЪГАЄЮЩНМЈ
$msg.html('КЃЄРЄБ<em>ЅЙЁМЅбЁМЅзЅьЅпЅЂЅрЅГЁМЅЙЄЧ</em>ИТФъИјГЋУц!');
}
found = true;
}
});
$texts.each(function () {
var $text = $(this);
if ($text.length) {
var html = $text.html();
if (html.indexOf('ТЮИГЅ­ЅуЅѓЅкЁМЅѓ') > -1 && html.indexOf('1/13ЄоЄЧ') === -1) {
html = html.replace('ТЮИГЅ­ЅуЅѓЅкЁМЅѓ', 'ТЮИГЅ­ЅуЅѓЅкЁМЅѓ 1/13ЄоЄЧ');
$text.html(html);
found = true;
}
}
});
return found;
}
if (masterCampaignUpdateMessage()) {
return;
}
var attempts = 0;
var maxAttempts = 10;
var pollInterval = setInterval(function() {
attempts++;
if ($('.Master_Regist_Box').length && masterCampaignUpdateMessage()) {
clearInterval(pollInterval);
return;
}
if (attempts >= maxAttempts) {
clearInterval(pollInterval);
}
}, 100);
});
</script>
